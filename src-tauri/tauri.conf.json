{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CherryAgent",
  "version": "0.1.0",
  "identifier": "com.beeza.cherryagent",
  "build": {
    "frontendDist": "../desktop-ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "CherryAgent — Windows AI Assistant",
        "width": 1180,
        "height": 780,
        "minWidth": 860,
        "minHeight": 620,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8787 http://localhost:8787; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "externalBin": ["binaries/cherry-backend"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
