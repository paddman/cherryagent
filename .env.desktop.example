# CherryAgent Windows Desktop Runtime
CHERRY_HOST=127.0.0.1
CHERRY_PORT=8787

# Enable local PC automation tool pack.
CHERRY_DESKTOP_ENABLED=true
CHERRY_DESKTOP_BRIDGE_URL=http://127.0.0.1:8765
# Normally generated automatically by the desktop app and shared with the local backend process.
CHERRY_DESKTOP_BRIDGE_TOKEN=
CHERRY_DESKTOP_TIMEOUT_MS=20000

# Main OpenAI-compatible model.
CHERRY_LLM_BASE_URL=http://127.0.0.1:8000/v1
CHERRY_LLM_API_KEY=local
CHERRY_LLM_MODEL=qwen3.6-27b

# Optional multimodal vision model. Defaults can point at the same endpoint/model when it supports image input.
CHERRY_VISION_BASE_URL=http://127.0.0.1:8000/v1
CHERRY_VISION_API_KEY=local
CHERRY_VISION_MODEL=qwen3.6-27b
CHERRY_VISION_TIMEOUT_MS=60000

# Safe/local state operations may auto-run. Screen capture, microphone, window inspection,
# mouse, click, keyboard and other consequential desktop actions remain external approval-gated.
CHERRY_AUTO_APPROVE=safe,write
