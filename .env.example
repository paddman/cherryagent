# OpenAI-compatible LLM endpoint. Works with vLLM, SGLang, Ollama-compatible gateways, and hosted providers.
CHERRY_LLM_BASE_URL=http://127.0.0.1:8000/v1
CHERRY_LLM_API_KEY=local
CHERRY_LLM_MODEL=qwen3.6-27b

# Agent behavior
CHERRY_MAX_STEPS=12
CHERRY_MEMORY_FILE=.cherry/memory.json
CHERRY_WORKSPACE=./workspace

# Comma-separated risk levels that can execute without approval.
# Recommended default: safe,write
CHERRY_AUTO_APPROVE=safe,write

# Google Workspace authentication.
# Recommended for long-running servers: OAuth client + refresh token.
CHERRY_GOOGLE_CLIENT_ID=
CHERRY_GOOGLE_CLIENT_SECRET=
CHERRY_GOOGLE_REFRESH_TOKEN=

# Alternative for short-lived testing only. Access tokens expire.
CHERRY_GOOGLE_ACCESS_TOKEN=

# Usually leave unchanged.
CHERRY_GOOGLE_TOKEN_ENDPOINT=https://oauth2.googleapis.com/token

# HTTP server
CHERRY_HOST=0.0.0.0
CHERRY_PORT=8787
