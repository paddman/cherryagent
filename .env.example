# LLM Configuration
CHERRY_LLM_BASE_URL=http://127.0.0.1:8000/v1
CHERRY_LLM_API_KEY=local
CHERRY_LLM_MODEL=qwen3.6-27b
CHERRY_MAX_STEPS=24

# PostgreSQL Persistence
CHERRY_POSTGRES_HOST=localhost
CHERRY_POSTGRES_PORT=5432
CHERRY_POSTGRES_DATABASE=cherry_agent
CHERRY_POSTGRES_USER=postgres
CHERRY_POSTGRES_PASSWORD=postgres

# Redis Cache
CHERRY_REDIS_HOST=localhost
CHERRY_REDIS_PORT=6379
CHERRY_REDIS_PASSWORD=

# Google Workspace
CHERRY_GOOGLE_CLIENT_ID=
CHERRY_GOOGLE_CLIENT_SECRET=
CHERRY_GOOGLE_REFRESH_TOKEN=
CHERRY_GOOGLE_ACCESS_TOKEN=

# Notifications
CHERRY_NOTIFY_EMAIL_TO=
CHERRY_NOTIFY_SLACK_WEBHOOK=
CHERRY_NOTIFY_WEBHOOK_URL=
CHERRY_NOTIFY_LINE_CHANNEL_ACCESS_TOKEN=
CHERRY_NOTIFY_LINE_TO=

# Planner
CHERRY_SCHEDULER_INTERVAL_MS=15000
CHERRY_DEFAULT_TIMEZONE=Asia/Bangkok

# Safety
CHERRY_AUTO_APPROVE=safe,write

# Server
PORT=8787
NODE_ENV=development
