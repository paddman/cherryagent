# OpenAI-compatible LLM endpoint. Works with vLLM, SGLang, Ollama-compatible gateways, and hosted providers.
CHERRY_LLM_BASE_URL=http://127.0.0.1:8000/v1
CHERRY_LLM_API_KEY=local
CHERRY_LLM_MODEL=qwen3.6-27b

# Agent behavior. Engineer loops can consume several tool/observe/verify steps.
CHERRY_MAX_STEPS=24

# Independent correctness passes before a final answer is accepted.
# Allowed range: 1-5. Default: 3.
CHERRY_CORRECTNESS_MAX_PASSES=3

CHERRY_MEMORY_FILE=.cherry/memory.json
CHERRY_PLANNER_FILE=.cherry/planner.json
CHERRY_ENGINEER_FILE=.cherry/engineer.json
CHERRY_AGENTIC_FILE=.cherry/agentic.json
CHERRY_WORKSPACE=./workspace

# BidPilot TOR/RFP document processing.
# PDF text extraction uses Poppler's pdftotext. Scanned PDFs fall back to
# pdftoppm + Tesseract OCR with Thai and English language data.
CHERRY_BIDPILOT_PDFTOTEXT_BIN=pdftotext
CHERRY_BIDPILOT_PDFTOPPM_BIN=pdftoppm
CHERRY_BIDPILOT_TESSERACT_BIN=tesseract
CHERRY_BIDPILOT_OCR_LANGUAGES=tha+eng
CHERRY_BIDPILOT_MAX_OCR_PAGES=30
CHERRY_BIDPILOT_TIMEOUT_MS=120000
CHERRY_BIDPILOT_MAX_DOCUMENT_BYTES=25000000

# Multi-agent orchestration budgets.
# Goal decomposition creates at most this many delegated tasks per run.
CHERRY_AGENTIC_MAX_TASKS=8
# Critic repair rounds after the first delegation pass.
CHERRY_AGENTIC_MAX_ROUNDS=2
# Maximum sub-agents executed in parallel.
CHERRY_AGENTIC_CONCURRENCY=3
# Tool-calling steps available to each specialist sub-agent.
CHERRY_SUBAGENT_MAX_STEPS=10

# Persistent reminder scheduler. Default: check every 15 seconds.
CHERRY_SCHEDULER_INTERVAL_MS=15000

# Comma-separated risk levels that can execute without approval.
# Recommended default: safe,write. Real trading orders and destructive DB/infra actions should not be auto-approved.
CHERRY_AUTO_APPROVE=safe,write

# Generic database agent.
# Requires the corresponding CLI in PATH: psql, mysql, sqlite3, or redis-cli.
CHERRY_DB_TIMEOUT_MS=30000
CHERRY_DB_MAX_OUTPUT_BYTES=1000000
CHERRY_DB_POSTGRES_URL=
CHERRY_DB_MYSQL_URL=
CHERRY_DB_SQLITE_PATH=
CHERRY_DB_REDIS_URL=

# Market data, financials and news timeout/localization.
CHERRY_MARKET_TIMEOUT_MS=20000
CHERRY_MARKET_NEWS_LANGUAGE=th
CHERRY_MARKET_NEWS_COUNTRY=TH

# Crypto exchange trading credentials. Public market data works without these keys.
# Binance Spot API
CHERRY_BINANCE_API_KEY=
CHERRY_BINANCE_API_SECRET=

# MEXC Spot API
CHERRY_MEXC_API_KEY=
CHERRY_MEXC_API_SECRET=

# Bitkub API V3 trading endpoints
CHERRY_BITKUB_API_KEY=
CHERRY_BITKUB_API_SECRET=

# XT Spot API V4
CHERRY_XT_APP_KEY=
CHERRY_XT_SECRET_KEY=

# Linux SSH capability pack.
# Uses the system OpenSSH client in BatchMode; key/agent authentication is recommended.
CHERRY_LINUX_SSH_HOST=
CHERRY_LINUX_SSH_USERNAME=
CHERRY_LINUX_SSH_PORT=22
CHERRY_LINUX_SSH_PRIVATE_KEY=
CHERRY_LINUX_SSH_KNOWN_HOSTS=
CHERRY_LINUX_SSH_STRICT_HOST_KEY_CHECKING=true
CHERRY_LINUX_SSH_TIMEOUT_MS=30000
CHERRY_LINUX_SSH_MAX_OUTPUT_BYTES=1000000

# Infrastructure API timeout shared by Proxmox and vSphere connectors.
CHERRY_INFRA_TIMEOUT_MS=20000

# Local Prometheus and Grafana observability.
# Tokens are optional when the APIs are trusted and unauthenticated inside the LAN.
CHERRY_PROMETHEUS_BASE_URL=http://prometheus.internal:9090
CHERRY_PROMETHEUS_BEARER_TOKEN=
CHERRY_GRAFANA_BASE_URL=http://grafana.internal:3000
CHERRY_GRAFANA_API_TOKEN=
CHERRY_OBSERVABILITY_VERIFY_TLS=true
CHERRY_OBSERVABILITY_TIMEOUT_MS=20000

# AI cluster health PromQL. {{lookback}} is replaced with the requested duration, for example 60m.
# Defaults target NVIDIA DCGM exporter, Kubernetes and common HTTP server metrics.
# Override these expressions to match your actual metric names and labels.
CHERRY_OPS_GPU_UTIL_QUERY=avg(avg_over_time(DCGM_FI_DEV_GPU_UTIL[{{lookback}}]))
CHERRY_OPS_GPU_TEMP_QUERY=max(DCGM_FI_DEV_GPU_TEMP)
CHERRY_OPS_GPU_XID_QUERY=sum(increase(DCGM_FI_DEV_XID_ERRORS[{{lookback}}]))
CHERRY_OPS_ERROR_RATE_QUERY=sum(rate(http_requests_total{status=~"5.."}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 0.001)
CHERRY_OPS_TARGET_DOWN_QUERY=count(up == 0)
CHERRY_OPS_RESTART_QUERY=sum(increase(kube_pod_container_status_restarts_total[{{lookback}}]))
CHERRY_OPS_GPU_UTIL_LOW=10
CHERRY_OPS_GPU_TEMP_HIGH=82
CHERRY_OPS_ERROR_RATE_HIGH=0.05
CHERRY_OPS_RESTART_HIGH=3

# Proxmox VE API token authentication.
# Example base URL: https://pve.example.internal:8006
CHERRY_PROXMOX_BASE_URL=
CHERRY_PROXMOX_TOKEN_ID=
CHERRY_PROXMOX_TOKEN_SECRET=
CHERRY_PROXMOX_VERIFY_TLS=true

# VMware vCenter / vSphere Automation API.
# Example base URL: https://vcenter.example.internal
CHERRY_VSPHERE_BASE_URL=
CHERRY_VSPHERE_USERNAME=
CHERRY_VSPHERE_PASSWORD=
CHERRY_VSPHERE_VERIFY_TLS=true

# Google Workspace authentication.
# Recommended for long-running servers: OAuth client + refresh token.
CHERRY_GOOGLE_CLIENT_ID=
CHERRY_GOOGLE_CLIENT_SECRET=
CHERRY_GOOGLE_REFRESH_TOKEN=

# Alternative for short-lived testing only. Access tokens expire.
CHERRY_GOOGLE_ACCESS_TOKEN=

# Usually leave unchanged.
CHERRY_GOOGLE_TOKEN_ENDPOINT=https://oauth2.googleapis.com/token

# Conversational LINE Messaging API channel.
# Configure the LINE Developers Console webhook URL as:
# https://YOUR_PUBLIC_HOST/channels/line/webhook
CHERRY_LINE_CHANNEL_SECRET=
CHERRY_LINE_CHANNEL_ACCESS_TOKEN=

# Scheduled notification delivery.
# In-app and browser alerts work without server-side channel configuration.
# Email delivery uses Gmail through the Google Workspace connector above.
CHERRY_NOTIFY_EMAIL_TO=

# Slack incoming webhook URL.
CHERRY_NOTIFY_SLACK_WEBHOOK=

# Generic JSON webhook URL. Receives planner.alert events.
CHERRY_NOTIFY_WEBHOOK_URL=

# LINE Messaging API push delivery for planner notifications.
# CHERRY_LINE_CHANNEL_ACCESS_TOKEN is also accepted by the conversational LINE adapter.
CHERRY_NOTIFY_LINE_CHANNEL_ACCESS_TOKEN=
CHERRY_NOTIFY_LINE_TO=

# HTTP server
CHERRY_HOST=0.0.0.0
CHERRY_PORT=8787
